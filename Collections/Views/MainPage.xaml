<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Collections.Views.MainPage"
             Title="Moje Kolekcje">

    <Grid RowDefinitions="Auto, *" Padding="20">
        <HorizontalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <Entry x:Name="CollectionNameEntry" Placeholder="Nazwa nowej kolekcji..." WidthRequest="200" />
            <Button Text="Dodaj kolekcję" Clicked="OnAddCollectionClicked" />
        </HorizontalStackLayout>

        <CollectionView x:Name="CollectionsListView" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCollectionTapped" CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>