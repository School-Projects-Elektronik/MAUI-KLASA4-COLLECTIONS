<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Collections.Views.ItemEditPage"
             Title="Edycja Elementu">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Nazwa przedmiotu:" FontAttributes="Bold" />
        <Entry x:Name="ItemNameEntry" Placeholder="Wpisz nazwę..." />

        <Label Text="Opis / Detale:" FontAttributes="Bold" />
        <Editor x:Name="ItemDetailsEditor" Placeholder="Wpisz detale..." HeightRequest="150" />

        <Button Text="Zapisz" Clicked="OnSaveClicked" BackgroundColor="Green" TextColor="White" Margin="0,20,0,0"/>
    </VerticalStackLayout>
</ContentPage>